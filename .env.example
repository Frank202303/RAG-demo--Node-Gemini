# ---------- 方式 A：Vertex AI（Cloud Run / 本地服务账号 key.json）----------
# Cloud Run 有 K_SERVICE 时会自动走 Vertex。本地若同时配置了 GOOGLE_API_KEY，默认优先 AI Studio。
# 本地强制 Vertex：USE_VERTEX_AI=true（建议暂时去掉 GOOGLE_API_KEY）
# USE_VERTEX_AI=true
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\YourName\keys\service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Vertex 调用区域（与 Cloud Run 部署区域无关）；推荐 us-central1
GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.5-flash-lite
# 仅 Vertex 用（可选）：GEMINI_VERTEX_LOCATION=us-central1

# ---------- 方式 B：Google AI Studio（推荐本地日常开发）----------
GOOGLE_API_KEY=your-ai-studio-api-key
# 可选覆盖模型（默认短名 gemini-2.0-flash）
# GEMINI_MODEL=gemini-2.0-flash

# 服务端口
# PORT=3000
